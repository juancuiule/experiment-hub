{
  "name": "experiment-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @experiment-hub/frontend dev",
    "build": "pnpm --filter @experiment-hub/frontend build",
    "start": "pnpm --filter @experiment-hub/frontend start",
    "lint": "pnpm --filter @experiment-hub/frontend lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @experiment-hub/frontend test:e2e"
  }
}
